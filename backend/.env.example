# AlphaTrace Backend — Environment Variables
# Copy this file to .env and fill in your values

# ── Server ────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ── Google Gemini AI (Free) ─────────────────────────────────────
# Free API key: https://aistudio.google.com/app/apikey
# Model: gemini-2.5-flash-preview-04-17 (free tier)
GEMINI_API_KEY=your_gemini_api_key_here

# ── 0G Chain (EVM) ────────────────────────────────────────────
OG_CHAIN_RPC=https://evmrpc.0g.ai
OG_CHAIN_ID=16600
PRIVATE_KEY=your_wallet_private_key_here
CONTRACT_ADDRESS=your_deployed_contract_address_here
AGENT_ADDRESS=your_agent_wallet_address_here

# ── 0G Storage ────────────────────────────────────────────────
OG_STORAGE_RPC=https://rpc-storage.0g.ai
OG_INDEXER_RPC=https://indexer-storage.0g.ai

# ── CoinGecko ─────────────────────────────────────────────────
# Get free key at https://www.coingecko.com/en/api
COINGECKO_API_KEY=your_coingecko_api_key_here

# ── Agent Loop ────────────────────────────────────────────────
# How often the agent runs (in minutes)
AGENT_INTERVAL_MINUTES=5
